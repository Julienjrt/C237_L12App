<!DOCTYPE html>
<html>
<head>
    <title>Buy Ticket</title>

    <style>
        body {
            font-family: Arial;
            background: #f2f2f2;
            padding: 20px;
        }

        .box {
            background: white;
            padding: 20px;
            border-radius: 10px;
            max-width: 500px;
            margin: auto;
        }

        button {
            padding: 10px;
            background: green;
            color: white;
            border: none;
            cursor: pointer;
        }

        a {
            display: inline-block;
            margin-top: 10px;
        }
    </style>
</head>

<body>

<div class="box">

    <h1>Confirm Purchase of train ticket</h1>

    <h2><%= train.name %></h2>

    <p>departure: <%= train.departure %></p>
    <p>arrival: <%= train.arrival %></p>
    <p>platform: <%= train.platform %></p>
    <p>status: <%= train.status %></p>
    <p>Price: $<%= train.price %></p>

    <form action="/confirmbuy" method="POST">
        <input type="hidden" name="id" value="<%= train.id %>">
        <input type="number" name="quantity" value="1" min="1" required>

        <button type="submit">Confirm Buy</button>
    </form>

    <a href="/viewtraintickets">Cancel</a>

</div>

</body>
</html>