<!DOCTYPE html>
<html>
<head>
    <title>Edit Train Ticket</title>

    <style>
        body {
            font-family: Arial;
            background: #f2f2f2;
            padding: 20px;
        }

        .box {
            background: white;
            padding: 20px;
            max-width: 500px;
            margin: auto;
            border-radius: 10px;
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
        }

        button {
            width: 100%;
            padding: 10px;
            background: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
        }

        button:hover {
            background: #0056b3;
        }
    </style>
</head>

<body>

<div class="box">

    <h2>Edit Train Tickets</h2>

    <form action="/edit/<%= train.id %>" method="POST">

        <!-- hidden id -->
        <input type="hidden" name="id" value="<%= train.id %>">

        <label>Train Name</label>
        <input type="text" name="name" value="<%= train.name %>">

        <label>Departure</label>
        <input type="text" name="departure" value="<%= train.departure %>">

        <label>Arrival</label>
        <input type="text" name="arrival" value="<%= train.arrival %>">

        <label>Platform</label>
        <input type="text" name="platform" value="<%= train.platform %>">

        <label>Status</label>
        <select name="status">
            <option <%= train.status === "On Time" ? "selected" : "" %>>On Time</option>
            <option <%= train.status === "Delayed" ? "selected" : "" %>>Delayed</option>
        </select>

        <label>Price</label>
        <input type="number" step="0.01" name="price" value="<%= train.price %>">

        <button type="submit">Update Ticket</button>
        

    </form>

</div>

</body>
</html>